<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext HTTP traffic for user-configured endpoints.
         Users may configure local Ollama, vLLM, or other self-hosted
         LLM services on their LAN. Android's domain-config does not
         support IP subnet matching, so we allow cleartext globally.
         The user explicitly configures the endpoint — this is an
         informed choice, not a hidden default. -->
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>